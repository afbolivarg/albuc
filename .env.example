# App URL for this environment (local dev vs production).
# Passed to Supabase as emailRedirectTo → {{ .RedirectTo }} in the magic link template.
# Keep dashboard Site URL on production; dev emails use localhost via this env var.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
DATABASE_URL=""

GOOGLE_GENERATIVE_AI_API_KEY=""

LOG_LEVEL="info"
LOG_PRETTY=""
