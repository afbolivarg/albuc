# Site URL (for auth redirects; use your Vercel URL in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
DATABASE_URL=""

# AI (run pnpm setup to generate .env.local interactively)
# AI_PROVIDER: google | openai | anthropic
AI_PROVIDER="google"
AI_CHAT_MODEL=""
AI_EMBEDDING_PROVIDER="google"
AI_EMBEDDING_MODEL=""

# Provider API keys (set the one for your AI_PROVIDER and AI_EMBEDDING_PROVIDER)
GOOGLE_GENERATIVE_AI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
